{
  "name": "avalanche-org-mcp-server",
  "version": "0.1.1",
  "description": "MCP server for the Avalanche.org Public API map-layer endpoints",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "avalanche-org-mcp-server": "dist/src/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build --silent",
    "start": "node dist/src/index.js",
    "example": "npm run build --silent && node dist/src/example.js",
    "test": "npm run build --silent && node --test dist/test/*.test.js"
  },
  "keywords": [
    "mcp",
    "avalanche",
    "avalanche.org",
    "snow-data"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haydenwade/avalanche-org-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/haydenwade/avalanche-org-mcp-server/issues"
  },
  "homepage": "https://github.com/haydenwade/avalanche-org-mcp-server#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2"
  }
}
